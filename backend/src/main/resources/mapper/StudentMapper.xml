<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sdm.backend.mapper.StudentMapper">
    <resultMap id="BaseResultMap" type="com.sdm.backend.entity.Student">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="student_number" property="studentNumber"/>
        <result column="class_name" property="className"/>
        <result column="major" property="major"/>
        <result column="counselor_id" property="counselorId"/>
        <result column="enrollment_date" property="enrollmentDate"/>
    </resultMap>

    <insert id="insert" parameterType="com.sdm.backend.entity.Student" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student (user_id, student_number, class_name, major, counselor_id, enrollment_date)
        VALUES (#{userId}, #{studentNumber}, #{className}, #{major}, #{counselorId}, #{enrollmentDate})
    </insert>

    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM student WHERE user_id = #{userId}
    </select>

    <select id="findByStudentNumber" resultMap="BaseResultMap">
        SELECT * FROM student WHERE student_number = #{studentNumber}
    </select>

    <update id="update" parameterType="com.sdm.backend.entity.Student">
        UPDATE student
        <set>
            <if test="studentNumber != null">student_number = #{studentNumber},</if>
            <if test="className != null">class_name = #{className},</if>
            <if test="major != null">major = #{major},</if>
            <if test="counselorId != null">counselor_id = #{counselorId},</if>
            <if test="enrollmentDate != null">enrollment_date = #{enrollmentDate},</if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <delete id="deleteByUserId">
        DELETE FROM student WHERE user_id = #{userId}
    </delete>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT s.*, u.real_name
        FROM student s
        LEFT JOIN user u ON s.user_id = u.id
        ORDER BY s.student_number
    </select>
</mapper>
