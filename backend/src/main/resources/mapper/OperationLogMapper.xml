<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sdm.backend.mapper.OperationLogMapper">
    <resultMap id="BaseResultMap" type="com.sdm.backend.entity.OperationLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="real_name" property="realName"/>
        <result column="role" property="role"/>
        <result column="operation" property="operation"/>
        <result column="module" property="module"/>
        <result column="description" property="description"/>
        <result column="request_method" property="requestMethod"/>
        <result column="request_url" property="requestUrl"/>
        <result column="request_params" property="requestParams"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="user_agent" property="userAgent"/>
        <result column="operation_time" property="operationTime"/>
        <result column="execution_time" property="executionTime"/>
        <result column="status" property="status"/>
        <result column="error_message" property="errorMessage"/>
    </resultMap>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM operation_log WHERE id = #{id}
    </select>

    <select id="findByPage" resultMap="BaseResultMap">
        SELECT * FROM operation_log ORDER BY operation_time DESC LIMIT #{offset}, #{limit}
    </select>

    <select id="findByPageAndFilters" resultMap="BaseResultMap">
        SELECT * FROM operation_log
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
            <if test="operation != null and operation != ''">
                AND operation = #{operation}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND operation_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND operation_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY operation_time DESC LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM operation_log
    </select>

    <select id="countByFilters" resultType="int">
        SELECT COUNT(*) FROM operation_log
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="module != null and module != ''">
                AND module = #{module}
            </if>
            <if test="operation != null and operation != ''">
                AND operation = #{operation}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND operation_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND operation_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <insert id="insert" parameterType="com.sdm.backend.entity.OperationLog" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log (user_id, username, real_name, role, operation, module, description, 
                                  request_method, request_url, request_params, ip_address, user_agent, 
                                  operation_time, execution_time, status, error_message)
        VALUES (#{userId}, #{username}, #{realName}, #{role}, #{operation}, #{module}, #{description},
                #{requestMethod}, #{requestUrl}, #{requestParams}, #{ipAddress}, #{userAgent},
                #{operationTime}, #{executionTime}, #{status}, #{errorMessage})
    </insert>

    <delete id="deleteById">
        DELETE FROM operation_log WHERE id = #{id}
    </delete>
</mapper>
